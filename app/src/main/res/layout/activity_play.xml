<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/background_image"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/back_battle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/enemy_platform"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitCenter"
        android:src="@drawable/place_battle"
        app:layout_constraintBottom_toTopOf="@+id/battle_menu_container"
        app:layout_constraintDimensionRatio="1:0.6"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.9"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.47000003"
        app:layout_constraintWidth_percent="0.65" />

    <ImageView
        android:id="@+id/imgPokeEnemy"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="110dp"
        app:layout_constraintBottom_toBottomOf="@+id/enemy_platform"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="@+id/enemy_platform"
        app:layout_constraintStart_toStartOf="@+id/enemy_platform"
        app:layout_constraintTop_toTopOf="@+id/enemy_platform"
        app:layout_constraintWidth_percent="0.35"
        tools:srcCompat="@tools:sample/avatars" />

    <TextView
        android:id="@+id/numVague"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_margin="8dp"
        android:fontFamily="@font/roboto_bold"
        android:gravity="center"
        android:maxLines="1"
        android:padding="4dp"
        android:shadowColor="#333333"
        android:shadowDx="5"
        android:shadowDy="5"
        android:shadowRadius="0.1"
        android:text="Vague n°1"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/statsButtonEnemy"
        android:layout_width="82dp"
        android:layout_height="33dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="25dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/enemy_items_container"
        app:srcCompat="@drawable/rounded_back_orange_small_border" />

    <TextView
        android:id="@+id/textView15"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/roboto_bold"
        android:text="Info"
        android:textColor="#5B0101"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="@+id/statsButtonEnemy"
        app:layout_constraintEnd_toEndOf="@+id/statsButtonEnemy"
        app:layout_constraintStart_toStartOf="@+id/statsButtonEnemy"
        app:layout_constraintTop_toTopOf="@+id/statsButtonEnemy" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/enemy_info_container"
        android:layout_width="286dp"
        android:layout_height="88dp"
        android:layout_marginStart="-12dp"
        android:layout_marginTop="42dp"
        app:layout_constraintBottom_toTopOf="@+id/imgPokeEnemy"
        app:layout_constraintHeight_percent="0.12"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.75"
        app:layout_constraintWidth_percent="0.7">

        <ImageView
            android:layout_width="284dp"
            android:layout_height="77dp"
            android:scaleType="fitXY"
            android:scaleX="-1"
            android:src="@drawable/item_info_poke_battle"
            tools:layout_editor_absoluteX="1dp"
            tools:layout_editor_absoluteY="14dp" />

        <TextView
            android:id="@+id/txt_enemy_lvl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="70dp"
            android:fontFamily="@font/roboto_bold"
            android:text="Lv5"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBaseline_toBaselineOf="@+id/txt_enemy_name"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/txt_enemy_name"
            android:layout_width="141dp"
            android:layout_height="28dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="4dp"
            android:fontFamily="@font/roboto_bold"
            android:maxLines="1"
            android:text="Bulbasaur"
            android:textColor="#000000"
            android:textSize="26sp"
            android:textStyle="bold"
            app:autoSizeMaxTextSize="30sp"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeTextType="uniform"
            app:layout_constraintBottom_toTopOf="@+id/enemy_hp_bar_container"
            app:layout_constraintEnd_toStartOf="@+id/txt_enemy_lvl"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <FrameLayout
            android:id="@+id/enemy_hp_bar_container"
            android:layout_width="0dp"
            android:layout_height="12dp"
            android:layout_marginBottom="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@+id/txt_enemy_lvl"
            app:layout_constraintStart_toStartOf="@+id/txt_enemy_name"
            app:layout_constraintTop_toBottomOf="@+id/txt_enemy_name">

            <ProgressBar
                android:id="@+id/enemy_hp_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:max="100"
                android:progress="100"
                android:progressDrawable="@drawable/hp_bar_green" />
        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/enemy_items_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="2dp"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="@+id/enemy_info_container"
        app:layout_constraintTop_toBottomOf="@+id/enemy_info_container" />

    <ImageView
        android:id="@+id/player_platform"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitCenter"
        android:src="@drawable/place_battle"
        app:layout_constraintBottom_toTopOf="@+id/battle_menu_container"
        app:layout_constraintDimensionRatio="1:0.6"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.89"
        app:layout_constraintWidth_percent="0.7" />

    <ImageView
        android:id="@+id/imgPokePlayer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="70dp"
        app:layout_constraintBottom_toBottomOf="@+id/player_platform"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="@+id/player_platform"
        app:layout_constraintHorizontal_bias="0.43"
        app:layout_constraintStart_toStartOf="@+id/player_platform"
        app:layout_constraintWidth_percent="0.37"
        tools:srcCompat="@tools:sample/avatars" />

    <ImageView
        android:id="@+id/return_btn"
        android:layout_width="64dp"
        android:layout_height="53dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/return_btn" />

    <ImageView
        android:id="@+id/statsButtonPlayer"
        android:layout_width="82dp"
        android:layout_height="33dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="25dp"
        app:layout_constraintBottom_toTopOf="@+id/player_info_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/rounded_back_orange_small_border" />

    <TextView
        android:id="@+id/textView16"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/roboto_bold"
        android:text="Stats"
        android:textColor="#01255B"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="@+id/statsButtonPlayer"
        app:layout_constraintEnd_toEndOf="@+id/statsButtonPlayer"
        app:layout_constraintStart_toStartOf="@+id/statsButtonPlayer"
        app:layout_constraintTop_toTopOf="@+id/statsButtonPlayer" />

    <LinearLayout
        android:id="@+id/player_items_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="2dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/player_info_container"
        app:layout_constraintEnd_toEndOf="@+id/player_info_container" >

    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/player_info_container"
        android:layout_width="291dp"
        android:layout_height="90dp"
        android:layout_marginEnd="-12dp"
        app:layout_constraintBottom_toTopOf="@+id/battle_menu_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.12"
        app:layout_constraintTop_toBottomOf="@+id/imgPokePlayer"
        app:layout_constraintVertical_bias="0.87"
        app:layout_constraintWidth_percent="0.7">

        <ImageView
            android:layout_width="283dp"
            android:layout_height="83dp"
            android:scaleType="fitXY"
            android:src="@drawable/item_info_poke_battle"
            tools:layout_editor_absoluteX="5dp"
            tools:layout_editor_absoluteY="5dp" />

        <TextView
            android:id="@+id/txt_player_lvl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="24dp"
            android:fontFamily="@font/roboto_bold"
            android:text="Lv5"
            android:textColor="#000000"
            android:textSize="20sp"
            app:layout_constraintBaseline_toBaselineOf="@+id/txt_player_name"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/txt_player_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="70dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="4dp"
            android:fontFamily="@font/roboto_bold"
            android:maxLines="1"
            android:text="Torchic"
            android:textColor="#000000"
            android:textSize="26sp"
            app:autoSizeMaxTextSize="30sp"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeTextType="uniform"
            app:layout_constraintBottom_toTopOf="@+id/player_hp_bar_container"
            app:layout_constraintEnd_toStartOf="@+id/txt_player_lvl"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <FrameLayout
            android:id="@+id/player_hp_bar_container"
            android:layout_width="0dp"
            android:layout_height="12dp"
            app:layout_constraintBottom_toTopOf="@+id/txt_player_hp_text"
            app:layout_constraintEnd_toEndOf="@+id/txt_player_lvl"
            app:layout_constraintStart_toStartOf="@+id/txt_player_name"
            app:layout_constraintTop_toBottomOf="@+id/txt_player_name">

            <ProgressBar
                android:id="@+id/player_hp_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:max="100"
                android:progress="50"
                android:progressDrawable="@drawable/hp_bar_green" />
        </FrameLayout>

        <TextView
            android:id="@+id/txt_player_hp_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/roboto_bold"
            android:text="20 / 20"
            android:textColor="#000000"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@+id/player_hp_bar_container"
            app:layout_constraintTop_toBottomOf="@+id/player_hp_bar_container" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/battle_menu_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bottom_battle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHeight_percent="0.32">
        <ImageView
            android:id="@+id/dialog_box"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="12dp"
            android:scaleType="fitXY"
            app:layout_constraintBottom_toTopOf="@+id/action_menu_wrapper"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_weight="1"
            app:srcCompat="@drawable/dialog_box_battle" />
        <TextView
            android:id="@+id/txt_dialogue_battle"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="16dp"
            android:fontFamily="@font/roboto_bold"
            android:text="Que doit faire le Pokémon ?"
            android:textColor="#000000"
            android:textSize="20sp"
            app:layout_constraintBottom_toBottomOf="@+id/dialog_box"
            app:layout_constraintEnd_toEndOf="@+id/dialog_box"
            app:layout_constraintStart_toStartOf="@+id/dialog_box"
            app:layout_constraintTop_toTopOf="@+id/dialog_box" />
        <FrameLayout
            android:id="@+id/action_menu_wrapper"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/dialog_box"
            app:layout_constraintVertical_weight="1">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_menu_principal"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/btn_attack_container"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="12dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/btn_team_container"
                    app:layout_constraintHorizontal_weight="2"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <ImageView
                        android:id="@+id/imageView10"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitXY"
                        app:srcCompat="@drawable/attack_btn_battle" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:fontFamily="@font/pixel"
                        android:gravity="center"
                        android:padding="30sp"
                        android:shadowColor="#333333"
                        android:shadowDx="5"
                        android:shadowDy="5"
                        android:shadowRadius="0.1"
                        android:text="ATTAQUER"
                        android:textColor="#FFFFFF"
                        android:textSize="30sp"
                        app:autoSizeMaxTextSize="100sp"
                        app:autoSizeMinTextSize="10sp"
                        app:autoSizeTextType="uniform"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/btn_team_container"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/rounded_back_orange_small_border2"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_weight="0.8"
                    app:layout_constraintStart_toEndOf="@+id/btn_attack_container"
                    app:layout_constraintTop_toTopOf="parent">
                    <ImageView
                        android:id="@+id/icon_pokeball"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_margin="8dp"
                        app:layout_constraintBottom_toTopOf="@+id/txt_team"
                        app:layout_constraintDimensionRatio="1:1"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:srcCompat="@drawable/pokeball" />
                    <TextView
                        android:id="@+id/txt_team"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:fontFamily="@font/pixel"
                        android:gravity="center"
                        android:shadowColor="#FFFFFF"
                        android:shadowDx="4"
                        android:shadowDy="4"
                        android:shadowRadius="0.1"
                        android:text="Équipe"
                        android:textColor="#000000"
                        android:textSize="18sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_menu_attacks"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">
                <ImageView
                    android:id="@+id/btn_return_attacks"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="8dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:srcCompat="@drawable/return_btn" />
                <GridLayout
                    android:id="@+id/attacks_grid"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="8dp"
                    android:columnCount="2"
                    android:rowCount="2"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/btn_return_attacks"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_menu_equipe"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#D9000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <TextView
            android:id="@+id/title_team"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/pixel"
            android:text="Mon Équipe"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btn_close_team"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_margin="16dp"
            android:src="@drawable/return_btn"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_margin="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/title_team">

            <LinearLayout
                android:id="@+id/team_list_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>